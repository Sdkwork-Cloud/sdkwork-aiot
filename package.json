{
  "name": "sdkwork-aiot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SDKWork AIoT server workspace with topology v2 dev orchestration.",
  "dependencies": {
    "@sdkwork/app-topology": "workspace:*"
  },
  "scripts": {
    "stop": "pnpm exec sdkwork-app stop",
    "dev": "pnpm dev:standalone",
    "dev:server:sqlite:standalone": "node scripts/aiot-dev.mjs --deployment-profile standalone --database sqlite",
    "start": "cargo run -p sdkwork-aiot-app-api",
    "build": "pnpm exec sdkwork-app build",
    "test": "pnpm exec sdkwork-app test",
    "test:rust": "cargo test --workspace",
    "test:workspace-standard": "node --test tests/aiot-workspace-standard.test.mjs",
    "check": "pnpm exec sdkwork-app check",
    "check:pnpm-script-standard": "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --application-code-prefix aiot",
    "check:agent-workflow-standard": "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root .",
    "verify": "pnpm exec sdkwork-app verify",
    "clean": "pnpm exec sdkwork-app clean",
    "topology:validate": "pnpm test:topology-validate",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "api:materialize": "node scripts/dev/sync-openapi-web-context.mjs",
    "api:materialize:check": "node scripts/dev/sync-openapi-web-context.mjs --check",
    "api:check": "pnpm test:app-openapi-context && pnpm test:openapi-web-context && pnpm api:materialize:check",
    "sdk:generate": "node tools/aiot_sdk_generate.mjs",
    "sdk:generate:check": "node tools/aiot_sdk_generate.mjs --check",
    "sdk:check": "pnpm sdk:generate:check",
    "gateway:run": "pnpm gateway:run:cloud",
    "gateway:build": "pnpm gateway:build:cloud",
    "gateway:package": "pnpm gateway:package:cloud",
    "gateway:validate": "pnpm gateway:validate:cloud",
    "gateway:plan": "pnpm topology:plan",
    "release:build": "pnpm build",
    "release:validate": "pnpm check && pnpm gateway:validate && pnpm test:release-package && pnpm test:release-publish && pnpm check:release-artifacts && pnpm sbom:check",
    "release:publish": "node scripts/release-publish.mjs",
    "release:plan": "pnpm topology:plan",
    "deploy:plan": "pnpm topology:plan",
    "deploy:validate": "pnpm topology:validate && pnpm check:deploy-manifest && pnpm gateway:validate",
    "release:preflight": "node scripts/release-preflight.mjs",
    "sbom:generate": "node scripts/sbom-generate.mjs",
    "sbom:check": "node scripts/sbom-check.mjs",
    "test:topology-baggage": "node --test scripts/dev/sdkwork-aiot-topology-baggage.test.mjs",
    "test:device-database": "node --test scripts/dev/sdkwork-aiot-device-database.test.mjs",
    "test:postgres-migration-parity": "node --test scripts/dev/sdkwork-aiot-postgres-migration-parity.test.mjs",
    "test:release-package": "node --test scripts/dev/sdkwork-aiot-release-package.test.mjs",
    "test:release-publish": "node --test scripts/dev/sdkwork-aiot-release-publish.test.mjs",
    "test:production-topology": "node --test scripts/dev/sdkwork-aiot-production-topology.test.mjs",
    "test:deploy-manifest": "node --test scripts/dev/sdkwork-aiot-deploy-manifest.test.mjs",
    "test:release-preflight": "node --test scripts/dev/sdkwork-aiot-release-preflight.test.mjs",
    "test:app-openapi-context": "node --test scripts/dev/sdkwork-aiot-app-openapi-context.test.mjs",
    "test:openapi-web-context": "node --test scripts/dev/sdkwork-aiot-openapi-web-context.test.mjs",
    "test:topology-validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root .",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_aiot_baseline.sql --module-id aiot --owner aiot-platform --prefixes iot_ --engines postgres,sqlite",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "check:iam-module-manifest": "node scripts/dev/validate-iam-module-manifest.mjs",
    "check:app-manifest": "node scripts/dev/validate-app-manifest.mjs",
    "check:release-artifacts": "node scripts/dev/validate-release-artifacts.mjs",
    "check:production-topology": "node scripts/dev/validate-production-topology.mjs",
    "check:deploy-manifest": "node scripts/dev/validate-deploy-manifest.mjs",
    "check:docs-index": "node scripts/dev/validate-docs-index.mjs",
    "check:docs-standard": "node ../sdkwork-specs/tools/check-repository-docs-standard.mjs --root . --profile application",
    "check:drive-standard": "node --test scripts/dev/drive-standard-contract.test.mjs",
    "check:api-envelope": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .",
    "check:pagination": "node ../sdkwork-specs/tools/check-pagination.mjs --workspace .",
    "check:app-sdk-consumer-imports": "node ../sdkwork-specs/tools/check-app-sdk-consumer-imports.mjs --workspace .",
    "release:package": "node scripts/release-package.mjs",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "gateway:run:standalone": "cargo run -p sdkwork-aiot-standalone-gateway --bin sdkwork-aiot-standalone-gateway",
    "gateway:build:standalone": "cargo build -p sdkwork-aiot-standalone-gateway --bin sdkwork-aiot-standalone-gateway",
    "gateway:package:standalone": "cargo build -p sdkwork-aiot-standalone-gateway --release --bin sdkwork-aiot-standalone-gateway",
    "gateway:validate:standalone": "cargo check -p sdkwork-aiot-standalone-gateway",
    "api:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "api:assembly:validate": "node scripts/gateway/assembly-validate.mjs",
    "_sdkwork:build": "cargo build --release -p sdkwork-aiot-cloud-gateway -p sdkwork-aiot-app-api -p sdkwork-aiot-admin-api",
    "_sdkwork:test": "node --test tests/aiot-workspace-standard.test.mjs && node --test scripts/dev/*.test.mjs && cargo test -p sdkwork-aiot-architecture && cargo test -p sdkwork-iot-platform-service",
    "_sdkwork:check": "pnpm run check:app-composition && pnpm test:workspace-standard && pnpm test:device-database && pnpm test:postgres-migration-parity && pnpm test:production-topology && pnpm test:deploy-manifest && pnpm test:release-preflight && pnpm check:pnpm-script-standard && pnpm check:agent-workflow-standard && pnpm check:docs-standard && pnpm check:docs-index && pnpm check:iam-module-manifest && pnpm check:app-manifest && pnpm check:production-topology && pnpm check:deploy-manifest && pnpm check:drive-standard && pnpm check:api-envelope && pnpm check:pagination && pnpm check:app-sdk-consumer-imports && pnpm db:validate && pnpm api:check && pnpm sdk:check && pnpm test:topology-validate && pnpm test:topology-baggage && cargo fmt -- --check && cargo clippy --workspace --tests -- -D warnings",
    "_sdkwork:verify": "pnpm check && cargo test --workspace && pnpm run check:app-composition",
    "_sdkwork:clean": "cargo clean",
    "dev:standalone": "pnpm exec sdkwork-app dev --deployment-profile standalone",
    "dev:cloud": "pnpm exec sdkwork-app dev --deployment-profile cloud",
    "release:preflight:standalone": "pnpm exec sdkwork-app release:preflight --deployment-profile standalone",
    "release:preflight:cloud": "pnpm exec sdkwork-app release:preflight --deployment-profile cloud",
    "release:plan:standalone": "pnpm exec sdkwork-app release:plan --deployment-profile standalone",
    "release:plan:cloud": "pnpm exec sdkwork-app release:plan --deployment-profile cloud",
    "release:build:standalone": "pnpm exec sdkwork-app release:build --deployment-profile standalone",
    "release:build:cloud": "pnpm exec sdkwork-app release:build --deployment-profile cloud",
    "release:package:standalone": "pnpm exec sdkwork-app release:package --deployment-profile standalone",
    "release:package:cloud": "pnpm exec sdkwork-app release:package --deployment-profile cloud",
    "release:validate:standalone": "pnpm exec sdkwork-app release:validate --deployment-profile standalone",
    "release:validate:cloud": "pnpm exec sdkwork-app release:validate --deployment-profile cloud",
    "release:publish:standalone": "pnpm exec sdkwork-app release:publish --deployment-profile standalone",
    "release:publish:cloud": "pnpm exec sdkwork-app release:publish --deployment-profile cloud",
    "deploy:plan:standalone": "pnpm exec sdkwork-app deploy:plan --deployment-profile standalone",
    "deploy:plan:cloud": "pnpm exec sdkwork-app deploy:plan --deployment-profile cloud",
    "deploy:validate:standalone": "pnpm exec sdkwork-app deploy:validate --deployment-profile standalone",
    "deploy:validate:cloud": "pnpm exec sdkwork-app deploy:validate --deployment-profile cloud",
    "dev:server:cloud": "pnpm exec sdkwork-app dev --runtime-target server --deployment-profile cloud"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
