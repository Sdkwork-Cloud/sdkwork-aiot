# standalone.production
SDKWORK_AIOT_DEPLOYMENT_PROFILE=standalone
SDKWORK_AIOT_ENVIRONMENT=production
SDKWORK_AIOT_PROFILE_ID=standalone.production

# Durable SQLite device database path (credentials, protocol ingest, outbox, admin entities).
SDKWORK_AIOT_DEVICE_DB_PATH=/var/lib/sdkwork-aiot/device.db
SDKWORK_AIOT_OUTBOX_DISPATCHER_ENABLED=1
SDKWORK_AIOT_OUTBOX_WEBHOOK_URL=http://127.0.0.1:8090/iot/outbox
# SDKWORK_AIOT_OUTBOX_LAG_READY_THRESHOLD=10000

# Production security gates — inject live secrets at deploy time.
SDKWORK_AIOT_INTERNAL_TOKEN=DEPLOY_INJECT:internal-token-min-32-characters-required
SDKWORK_AIOT_CREDENTIAL_PEPPER=DEPLOY_INJECT:credential-pepper-min-32-characters-required
SDKWORK_AIOT_CORS_ALLOWED_ORIGINS=https://console.aiot.local
SDKWORK_AIOT_TRUST_PROXY_HEADERS=1

# Fail closed when no explicit MCP policy rule matches (production default).
SDKWORK_AIOT_XIAOZHI_MCP_POLICY_DENY_BY_DEFAULT=1

# Production intelligence (required when SDKWORK_AIOT_ENVIRONMENT=production).
SDKWORK_AIOT_INTELLIGENCE_MODE=kernel
SDKWORK_AIOT_INTELLIGENCE_KERNEL_HTTP_URL=DEPLOY_INJECT:kernel-http-url
SDKWORK_CLAW_ROUTER_APPLICATION_OPEN_HTTP_URL=DEPLOY_INJECT:claw-router-http-url
SDKWORK_CLAW_ROUTER_API_KEY=DEPLOY_INJECT:claw-router-api-key-min-32-characters

SDKWORK_AIOT_APPLICATION_APP_HTTP_BIND=0.0.0.0:18082
SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=http://aiot.local:18082/app/v3/api/iot

SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_BIND=0.0.0.0:18081
SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=http://aiot.local:18081/backend/v3/api/iot

SDKWORK_AIOT_EDGE_DEVICE_INGRESS_BIND=0.0.0.0:18080
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=http://edge.aiot.local:18080
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=ws://edge.aiot.local:18080
SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=http://api.local:3900

VITE_SDKWORK_AIOT_DEPLOYMENT_PROFILE=standalone
VITE_SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=http://aiot.local:18082/app/v3/api/iot
VITE_SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=http://aiot.local:18081/backend/v3/api/iot
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=http://edge.aiot.local:18080
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=ws://edge.aiot.local:18080
VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=http://api.local:3900
VITE_SDKWORK_DRIVE_APP_API_BASE_URL=http://api.local:3900
VITE_SDKWORK_AGENTS_APP_API_BASE_URL=http://agents.local:3901
VITE_SDKWORK_VOICE_APP_API_BASE_URL=http://voice.local:3902
