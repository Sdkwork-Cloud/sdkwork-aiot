# AIoT topology profile: cloud-hosted + split-services + development

SDKWORK_AIOT_HOSTING=cloud-hosted
SDKWORK_AIOT_SERVICE_LAYOUT=split-services
SDKWORK_AIOT_ENVIRONMENT=development
SDKWORK_AIOT_PROFILE_ID=cloud-hosted.split-services.development

# Local dev still uses shared SQLite under .sdkwork/dev when started via pnpm dev.
SDKWORK_AIOT_DEVICE_DB_PATH=.sdkwork/dev/aiot-device.db

SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=https://api-dev.sdkwork.com/app/v3/api/iot
SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=https://api-dev.sdkwork.com/backend/v3/api/iot
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=https://edge-dev.aiot.sdkwork.com
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=wss://edge-dev.aiot.sdkwork.com

SDKWORK_API_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_AIOT_PLATFORM_API_GATEWAY_AUTOSTART=true

VITE_SDKWORK_AIOT_HOSTING=cloud-hosted
VITE_SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=https://api-dev.sdkwork.com/app/v3/api/iot
VITE_SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=https://api-dev.sdkwork.com/backend/v3/api/iot
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=https://edge-dev.aiot.sdkwork.com
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=wss://edge-dev.aiot.sdkwork.com
VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
