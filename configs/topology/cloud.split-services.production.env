# cloud.split-services.production
SDKWORK_AIOT_DEPLOYMENT_PROFILE=cloud
SDKWORK_AIOT_SERVICE_LAYOUT=split-services
SDKWORK_AIOT_ENVIRONMENT=production
SDKWORK_AIOT_PROFILE_ID=cloud.split-services.production

# Cloud Postgres persistence (shared device/credential/outbox/admin-entity pool)
SDKWORK_AIOT_DEVICE_DATABASE_ENGINE=postgres
SDKWORK_AIOT_DEVICE_DATABASE_URL=postgres://DEPLOY_INJECT:username:DEPLOY_INJECT:password@DEPLOY_INJECT:host:5432/DEPLOY_INJECT:database?sslmode=require
SDKWORK_AIOT_DEVICE_DATABASE_TABLE_PREFIX=iot_
SDKWORK_AIOT_DEVICE_DATABASE_MODE=pool

# Outbox dispatch runs on edge gateway in split-services production.
SDKWORK_AIOT_OUTBOX_DISPATCHER_ENABLED=1
# SDKWORK_AIOT_OUTBOX_WEBHOOK_URL=https://events.sdkwork.com/iot/outbox
# SDKWORK_AIOT_OUTBOX_WEBHOOK_AUTH=Bearer DEPLOY_INJECT:outbox-webhook-token-min-32-chars
# SDKWORK_AIOT_OUTBOX_LAG_READY_THRESHOLD=10000

# Production security gates — inject live secrets at deploy time.
SDKWORK_AIOT_INTERNAL_TOKEN=DEPLOY_INJECT:internal-token-min-32-characters-required
SDKWORK_AIOT_CREDENTIAL_PEPPER=DEPLOY_INJECT:credential-pepper-min-32-characters-required
SDKWORK_AIOT_CORS_ALLOWED_ORIGINS=https://console.sdkwork.com
SDKWORK_AIOT_TRUST_PROXY_HEADERS=1

# Fail closed when no explicit MCP policy rule matches (production default).
SDKWORK_AIOT_XIAOZHI_MCP_POLICY_DENY_BY_DEFAULT=1

# Production intelligence (uncomment and inject at deploy time).
# SDKWORK_AIOT_INTELLIGENCE_MODE=kernel
# SDKWORK_AIOT_INTELLIGENCE_KERNEL_HTTP_URL=https://kernel.sdkwork.com
# SDKWORK_CLAW_ROUTER_APPLICATION_OPEN_HTTP_URL=https://claw-router.sdkwork.com
# SDKWORK_CLAW_ROUTER_API_KEY=DEPLOY_INJECT:claw-router-api-key-min-32-characters

SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=https://aiot.sdkwork.com/app/v3/api/iot
SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=https://aiot-admin.sdkwork.com/backend/v3/api/iot
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=https://edge.aiot.sdkwork.com
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=wss://edge.aiot.sdkwork.com

SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_AIOT_PLATFORM_API_GATEWAY_AUTOSTART=false
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.aiot.production.toml

VITE_SDKWORK_AIOT_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=https://aiot.sdkwork.com/app/v3/api/iot
VITE_SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=https://aiot-admin.sdkwork.com/backend/v3/api/iot
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=https://edge.aiot.sdkwork.com
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=wss://edge.aiot.sdkwork.com
VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
VITE_SDKWORK_DRIVE_APP_API_BASE_URL=https://api.sdkwork.com
