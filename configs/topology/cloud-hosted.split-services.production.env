# AIoT topology profile: cloud-hosted + split-services + production

SDKWORK_AIOT_HOSTING=cloud-hosted
SDKWORK_AIOT_SERVICE_LAYOUT=split-services
SDKWORK_AIOT_ENVIRONMENT=production
SDKWORK_AIOT_PROFILE_ID=cloud-hosted.split-services.production

SDKWORK_AIOT_DEVICE_DB_PATH=/var/lib/sdkwork-aiot/device.db
# Phase K (cloud HA): replace the SQLite path above with SDKWORK_AIOT_DEVICE_DATABASE_URL
# and SDKWORK_AIOT_DEVICE_DATABASE_ENGINE=postgres once postgres repositories land.
SDKWORK_AIOT_OUTBOX_DISPATCHER_ENABLED=1

# Production security gates (override at deploy time; minimum length enforced by topology validator).
SDKWORK_AIOT_INTERNAL_TOKEN=cloud-production-internal-token-rotate-at-deploy-32
SDKWORK_AIOT_CREDENTIAL_PEPPER=cloud-production-credential-pepper-rotate-at-deploy-32
SDKWORK_AIOT_CORS_ALLOWED_ORIGINS=https://console.sdkwork.com
SDKWORK_AIOT_TRUST_PROXY_HEADERS=1
# SDKWORK_AIOT_OUTBOX_WEBHOOK_URL=https://events.sdkwork.com/iot/outbox
# SDKWORK_AIOT_OUTBOX_WEBHOOK_AUTH=Bearer rotate-at-deploy
# SDKWORK_AIOT_OUTBOX_LAG_READY_THRESHOLD=10000

SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=https://aiot.sdkwork.com/app/v3/api/iot
SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=https://aiot-admin.sdkwork.com/backend/v3/api/iot
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=https://edge.aiot.sdkwork.com
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=wss://edge.aiot.sdkwork.com

SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_AIOT_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_AIOT_HOSTING=cloud-hosted
VITE_SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=https://aiot.sdkwork.com/app/v3/api/iot
VITE_SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=https://aiot-admin.sdkwork.com/backend/v3/api/iot
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=https://edge.aiot.sdkwork.com
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=wss://edge.aiot.sdkwork.com
VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
