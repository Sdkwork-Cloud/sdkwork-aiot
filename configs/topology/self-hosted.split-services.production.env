# AIoT topology profile: self-hosted + split-services + production

SDKWORK_AIOT_HOSTING=self-hosted
SDKWORK_AIOT_SERVICE_LAYOUT=split-services
SDKWORK_AIOT_ENVIRONMENT=production
SDKWORK_AIOT_PROFILE_ID=self-hosted.split-services.production

SDKWORK_AIOT_APPLICATION_APP_HTTP_BIND=0.0.0.0:18082
SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=http://aiot.local:18082

SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_BIND=0.0.0.0:18081
SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=http://aiot.local:18081

SDKWORK_AIOT_EDGE_DEVICE_INGRESS_BIND=0.0.0.0:18080
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=http://edge.aiot.local:18080
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=ws://edge.aiot.local:18080

SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=http://api.local:3900
SDKWORK_AIOT_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_AIOT_HOSTING=self-hosted
VITE_SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=http://aiot.local:18082
VITE_SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=http://aiot.local:18081
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=http://edge.aiot.local:18080
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=ws://edge.aiot.local:18080
VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=http://api.local:3900
