# AIoT topology profile: self-hosted + split-services + development

SDKWORK_AIOT_HOSTING=self-hosted
SDKWORK_AIOT_SERVICE_LAYOUT=split-services
SDKWORK_AIOT_ENVIRONMENT=development
SDKWORK_AIOT_PROFILE_ID=self-hosted.split-services.development

# Shared SQLite device database for split-services dev (protocol ingest, credentials, outbox).
# Override with an absolute path for persistent local testing.
SDKWORK_AIOT_DEVICE_DB_PATH=.sdkwork/dev/aiot-device.db
# Outbox dispatch ownership is assigned per process in scripts/aiot-dev.mjs
# (edge gateway enabled, HTTP APIs disabled).

SDKWORK_AIOT_APPLICATION_APP_HTTP_BIND=127.0.0.1:18082
SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=http://127.0.0.1:18082

SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_BIND=127.0.0.1:18081
SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=http://127.0.0.1:18081

SDKWORK_AIOT_EDGE_DEVICE_INGRESS_BIND=127.0.0.1:18080
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=http://127.0.0.1:18080
SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=ws://127.0.0.1:18080

SDKWORK_API_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_AIOT_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_AIOT_HOSTING=self-hosted
VITE_SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=http://127.0.0.1:18082
VITE_SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=http://127.0.0.1:18080
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=ws://127.0.0.1:18080
VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
