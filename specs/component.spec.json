{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-aiot",
    "displayName": "SDKWork AIoT Application",
    "version": "0.1.0",
    "type": "app",
    "root": ".",
    "domain": "iot",
    "capability": "device-platform",
    "languages": [
      "rust",
      "typescript"
    ],
    "generated": false,
    "manifests": [
      "Cargo.toml"
    ]
  },
  "canonicalSpecs": [
    {
      "file": "API_SPEC.md",
      "path": "../sdkwork-specs/API_SPEC.md",
      "purpose": "SDKWork v3 HTTP API prefixes, operationIds, OpenAPI, Problem Details, and generated SDK source-of-truth rules."
    },
    {
      "file": "SDK_SPEC.md",
      "path": "../sdkwork-specs/SDK_SPEC.md",
      "purpose": "Generated SDK package, auth header, resource-style client surface, and no raw HTTP fallback rules."
    },
    {
      "file": "DOMAIN_SPEC.md",
      "path": "../sdkwork-specs/DOMAIN_SPEC.md",
      "purpose": "Canonical domain naming, bounded context, capability ownership, and cross-domain references."
    },
    {
      "file": "DATABASE_SPEC.md",
      "path": "../sdkwork-specs/DATABASE_SPEC.md",
      "purpose": "Database prefix, table contract, tenant isolation, ownership, audit, and schema evolution rules."
    },
    {
      "file": "DATABASE_FRAMEWORK_SPEC.md",
      "path": "../sdkwork-specs/DATABASE_FRAMEWORK_SPEC.md",
      "purpose": "sdkwork-database lifecycle, migrations, seeds, drift observation, and bootstrap SPI."
    },
    {
      "file": "IAM_MODULE_MANIFEST_SPEC.md",
      "path": "../sdkwork-specs/IAM_MODULE_MANIFEST_SPEC.md",
      "purpose": "IMF module manifest schema for federated IAM permission and role catalogs."
    },
    {
      "file": "SDK_WORKSPACE_GENERATION_SPEC.md",
      "path": "../sdkwork-specs/SDK_WORKSPACE_GENERATION_SPEC.md",
      "purpose": "Application-root sdks/ workspace layout, OpenAPI authority inputs, and SDK generation boundaries."
    },
    {
      "file": "COMPONENT_SPEC.md",
      "path": "../sdkwork-specs/COMPONENT_SPEC.md",
      "purpose": "Local component manifest, public entrypoints, integration boundaries, and verification requirements."
    },
    {
      "file": "SECURITY_SPEC.md",
      "path": "../sdkwork-specs/SECURITY_SPEC.md",
      "purpose": "Dual-token app/backend security, device auth separation, authorization, logging, and abuse protection."
    },
    {
      "file": "OBSERVABILITY_SPEC.md",
      "path": "../sdkwork-specs/OBSERVABILITY_SPEC.md",
      "purpose": "Trace, metric, structured logging, audit correlation, and sensitive data redaction rules."
    },
    {
      "file": "TEST_SPEC.md",
      "path": "../sdkwork-specs/TEST_SPEC.md",
      "purpose": "Contract, architecture, integration, and verification standards."
    },
    {
      "file": "CODE_STYLE_SPEC.md",
      "path": "../sdkwork-specs/CODE_STYLE_SPEC.md",
      "purpose": "Authored source structure and generated code boundaries."
    },
    {
      "file": "NAMING_SPEC.md",
      "path": "../sdkwork-specs/NAMING_SPEC.md",
      "purpose": "Canonical SDKWork naming rules."
    },
    {
      "file": "MODULE_SPEC.md",
      "path": "../sdkwork-specs/MODULE_SPEC.md",
      "purpose": "Reusable module and package boundary rules."
    },
    {
      "file": "RUST_CODE_SPEC.md",
      "path": "../sdkwork-specs/RUST_CODE_SPEC.md",
      "purpose": "Rust crate and module rules."
    },
    {
      "file": "WEB_FRAMEWORK_SPEC.md",
      "path": "../sdkwork-specs/WEB_FRAMEWORK_SPEC.md",
      "purpose": "Mandatory sdkwork-web-framework integration for HTTP *-api surfaces."
    },
    {
      "file": "WEB_BACKEND_SPEC.md",
      "path": "../sdkwork-specs/WEB_BACKEND_SPEC.md",
      "purpose": "Handler, service, repository, and request-context layering for HTTP backends."
    },
    {
      "file": "DEPLOYMENT_SPEC.md",
      "path": "../sdkwork-specs/DEPLOYMENT_SPEC.md",
      "purpose": "Standalone/cloud deployment profile parity and runtime target coverage."
    },
    {
      "file": "GITHUB_WORKFLOW_SPEC.md",
      "path": "../sdkwork-specs/GITHUB_WORKFLOW_SPEC.md",
      "purpose": "sdkwork.workflow.json and reusable GitHub packaging workflow integration."
    },
    {
      "file": "APP_RUNTIME_TOPOLOGY_SPEC.md",
      "path": "../sdkwork-specs/APP_RUNTIME_TOPOLOGY_SPEC.md",
      "purpose": "Application runtime connectivity topology and dev orchestration profiles."
    },
    {
      "file": "API_ASSEMBLY_SPEC.md",
      "path": "../sdkwork-specs/API_ASSEMBLY_SPEC.md",
      "purpose": "Canonical host-neutral application HTTP API composition."
    },
    {
      "file": "APPLICATION_GATEWAY_SPEC.md",
      "path": "../sdkwork-specs/APPLICATION_GATEWAY_SPEC.md",
      "purpose": "Canonical standalone gateway and platform cloud gateway ownership boundaries."
    },
    {
      "file": "DRIVE_SPEC.md",
      "path": "../sdkwork-specs/DRIVE_SPEC.md",
      "purpose": "Drive Uploader, client upload SDK, and Drive-backed MediaResource ownership."
    },
    {
      "file": "MEDIA_RESOURCE_SPEC.md",
      "path": "../sdkwork-specs/MEDIA_RESOURCE_SPEC.md",
      "purpose": "Cross-domain MediaResource representation and Drive source mapping."
    }
  ],
  "contracts": {
    "layerRole": "runtime-composition",
    "iamModuleManifest": "specs/iam.module.manifest.json",
    "publicExports": [
      "crates/sdkwork-aiot-contract",
      "crates/sdkwork-iot-device-service",
      "crates/sdkwork-aiot-protocol",
      "crates/sdkwork-aiot-service-host",
      "crates/sdkwork-aiot-storage",
      "crates/sdkwork-aiot-app-context",
      "crates/sdkwork-aiot-security",
      "crates/sdkwork-aiot-observability",
      "crates/sdkwork-aiot-adapter-xiaozhi",
      "crates/sdkwork-iot-platform-service",
      "crates/sdkwork-routes-iot-app-api",
      "crates/sdkwork-routes-iot-backend-api",
      "crates/sdkwork-api-aiot-assembly"
    ],
    "runtimeEntrypoints": [
      "sdkwork_aiot_service_host::AiotRuntime::builder",
      "sdkwork_aiot_service_host::standard_aiot_runtime",
      "crates/sdkwork-api-aiot-assembly",
      "crates/sdkwork-api-aiot-standalone-gateway",
      "crates/sdkwork-aiot-device-edge-runtime",
      "services/sdkwork-aiot-xiaozhi-simulator-ui"
    ],
    "sdkClients": [
      "@sdkwork/aiot-app-sdk",
      "@sdkwork/aiot-backend-sdk",
      "@sdkwork/drive-app-sdk"
    ],
    "events": [
      "iot.device.registered",
      "iot.device.connected",
      "iot.command.created",
      "iot.twin.reported.updated",
      "iot.telemetry.received",
      "iot.security.deviceAuthFailed"
    ],
    "configKeys": [
      "AiotConfig",
      "AiotRuntimeBuilder",
      "RuntimeServicePlan"
    ],
    "routeManifest": [
      "sdks/_route-manifests/app-api/sdkwork-aiot-app-api.route-manifest.json",
      "sdks/_route-manifests/backend-api/sdkwork-aiot-admin-api.route-manifest.json"
    ],
    "openapiAuthorities": [
      "apis/app-api/iot/sdkwork-aiot-app-api.openapi.json",
      "apis/backend-api/iot/sdkwork-aiot-backend-api.openapi.json"
    ]
  },
  "protocolPluginStandard": {
    "manifest": "sdkwork_aiot_protocol::ProtocolAdapterManifest",
    "requiredFields": [
      "scope",
      "protocol_ids",
      "transports",
      "codecs",
      "session_policies",
      "capability_bridges",
      "security_modes",
      "hardware_families",
      "runtime_profiles",
      "firmware_profiles"
    ],
    "routeContract": "sdkwork_aiot_service_host::AiotProtocolRoute",
    "envelopeContract": "sdkwork_aiot_protocol::ProtocolEnvelope",
    "ingestContract": "sdkwork_iot_device_service::ProtocolIngestRecord",
    "firstPlugin": "xiaozhi"
  },
  "boundaries": {
    "externalSharedKernels": [
      "sdkwork-appbase.iam"
    ],
    "forbiddenComponents": [
      "sdkwork-aiot-iam"
    ],
    "forbiddenTables": [
      "iam_tenant",
      "iam_organization",
      "iam_user",
      "iam_role",
      "iam_permission",
      "iam_policy",
      "iam_credential"
    ],
    "deviceProtocolBasePaths": [
      "/iot/xiaozhi"
    ],
    "apiPrefixes": [
      "/app/v3/api/iot",
      "/backend/v3/api/iot"
    ]
  },
  "verification": {
    "commands": [
      "pnpm check",
      "pnpm verify",
      "pnpm deploy:validate",
      "pnpm release:validate",
      "pnpm release:preflight",
      "cargo fmt -- --check",
      "cargo test --workspace"
    ]
  }
}
