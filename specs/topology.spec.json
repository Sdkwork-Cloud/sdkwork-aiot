{
  "schemaVersion": 2,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-aiot",
  "archetype": "application-rest-edge-device",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{serviceLayout}.{environment}.env",
  "vocabulary": {
    "serviceLayout": {
      "allowed": [
        "split-services"
      ]
    },
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    },
    "connectivityPlane": {
      "allowed": [
        "application",
        "platform",
        "edge"
      ]
    },
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.split-services.development",
    "productionProfileId": "cloud.split-services.production",
    "gatewayBind": "127.0.0.1:3900"
  },
  "profileFiles": {
    "standalone.split-services.development": "configs/topology/standalone.split-services.development.env",
    "cloud.split-services.development": "configs/topology/cloud.split-services.development.env",
    "standalone.split-services.production": "configs/topology/standalone.split-services.production.env",
    "cloud.split-services.production": "configs/topology/cloud.split-services.production.env"
  },
  "envKeys": {
    "serviceLayout": "SDKWORK_AIOT_SERVICE_LAYOUT",
    "environment": "SDKWORK_AIOT_ENVIRONMENT",
    "profileId": "SDKWORK_AIOT_PROFILE_ID",
    "gatewayAutostart": "SDKWORK_AIOT_PLATFORM_API_GATEWAY_AUTOSTART",
    "cloudGatewayBind": "SDKWORK_API_CLOUD_GATEWAY_BIND",
    "apiGatewayBaseUrl": "SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL",
    "deploymentProfile": "SDKWORK_AIOT_DEPLOYMENT_PROFILE",
    "clientDeploymentProfile": "VITE_SDKWORK_AIOT_DEPLOYMENT_PROFILE"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_AIOT_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_AIOT_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_APPLICATION_PUBLIC_HTTP_URL"
    },
    "application.app-http": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_AIOT_APPLICATION_APP_HTTP_BIND",
      "httpUrlEnv": "SDKWORK_AIOT_APPLICATION_APP_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_APPLICATION_APP_HTTP_URL"
    },
    "application.admin-http": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_BIND",
      "httpUrlEnv": "SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL"
    },
    "edge.device-ingress": {
      "connectivityPlane": "edge",
      "protocols": [
        "http",
        "websocket",
        "mqtt",
        "udp"
      ],
      "bindEnv": "SDKWORK_AIOT_EDGE_DEVICE_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL",
      "websocketUrlEnv": "SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL",
      "clientWebsocketEnv": "VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "owner": "sdkwork-api-cloud-gateway",
      "bindEnv": "SDKWORK_API_CLOUD_GATEWAY_BIND",
      "httpUrlEnv": "SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL",
      "autostartEnv": "SDKWORK_AIOT_PLATFORM_API_GATEWAY_AUTOSTART"
    }
  },
  "cloudPublicHosts": {
    "application.app-http": {
      "httpHost": "aiot.sdkwork.com"
    },
    "application.admin-http": {
      "httpHost": "aiot-admin.sdkwork.com"
    },
    "edge.device-ingress": {
      "httpHost": "edge.aiot.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_AIOT",
    "devicePath": "SDKWORK_AIOT_DEVICE_DB_PATH",
    "deviceEngine": "SDKWORK_AIOT_DEVICE_DATABASE_ENGINE",
    "deviceTablePrefix": "SDKWORK_AIOT_DEVICE_DATABASE_TABLE_PREFIX",
    "deviceMode": "SDKWORK_AIOT_DEVICE_DATABASE_MODE",
    "outboxDispatcherEnabled": "SDKWORK_AIOT_OUTBOX_DISPATCHER_ENABLED",
    "outboxDispatchIntervalMs": "SDKWORK_AIOT_OUTBOX_DISPATCH_INTERVAL_MS",
    "outboxLagReadyThreshold": "SDKWORK_AIOT_OUTBOX_LAG_READY_THRESHOLD",
    "outboxWebhookUrl": "SDKWORK_AIOT_OUTBOX_WEBHOOK_URL"
  },
  "intelligence": {
    "mode": "SDKWORK_AIOT_INTELLIGENCE_MODE",
    "kernelHttpUrl": "SDKWORK_AIOT_INTELLIGENCE_KERNEL_HTTP_URL",
    "kernelAgentId": "SDKWORK_AIOT_INTELLIGENCE_KERNEL_AGENT_ID",
    "clawRouterOpenHttpUrl": "SDKWORK_CLAW_ROUTER_APPLICATION_OPEN_HTTP_URL",
    "clawRouterApiKey": "SDKWORK_CLAW_ROUTER_API_KEY",
    "asrModel": "SDKWORK_AIOT_INTELLIGENCE_ASR_MODEL",
    "ttsModel": "SDKWORK_AIOT_INTELLIGENCE_TTS_MODEL",
    "ttsVoice": "SDKWORK_AIOT_INTELLIGENCE_TTS_VOICE",
    "ttsResponseFormat": "SDKWORK_AIOT_INTELLIGENCE_TTS_RESPONSE_FORMAT",
    "ttsSampleRate": "SDKWORK_AIOT_INTELLIGENCE_TTS_SAMPLE_RATE"
  },
  "components": {
    "edgeGateway": {
      "crate": "sdkwork-aiot-cloud-gateway",
      "binary": "sdkwork-aiot-cloud-gateway"
    },
    "appApi": {
      "crate": "sdkwork-aiot-app-api",
      "binary": "sdkwork-aiot-app-api"
    },
    "adminApi": {
      "crate": "sdkwork-aiot-admin-api",
      "binary": "sdkwork-aiot-admin-api"
    },
    "standaloneGateway": {
      "crate": "sdkwork-aiot-standalone-gateway",
      "binary": "sdkwork-aiot-standalone-gateway"
    },
    "cloudGateway": {
      "crate": "sdkwork-api-cloud-gateway-api-server",
      "binary": "sdkwork-api-cloud-gateway",
      "repository": "sdkwork-api-cloud-gateway"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.split-services.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-aiot-standalone-gateway",
            "binary": "sdkwork-aiot-standalone-gateway",
            "required": true
          },
          {
            "id": "edge.device-ingress",
            "crate": "sdkwork-aiot-cloud-gateway",
            "binary": "sdkwork-aiot-cloud-gateway",
            "required": true
          },
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway-api-server",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": false
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "edge.device-ingress"
        ]
      },
      "cloud.split-services.development": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway-api-server",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": true
          },
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-aiot-standalone-gateway",
            "binary": "sdkwork-aiot-standalone-gateway",
            "required": true
          },
          {
            "id": "edge.device-ingress",
            "crate": "sdkwork-aiot-cloud-gateway",
            "binary": "sdkwork-aiot-cloud-gateway",
            "required": true
          }
        ],
        "healthSurfaces": [
          "platform.api-gateway",
          "application.public-ingress",
          "edge.device-ingress"
        ]
      },
      "cloud.split-services.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-aiot-standalone-gateway",
            "binary": "sdkwork-aiot-standalone-gateway",
            "required": true
          },
          {
            "id": "edge.device-ingress",
            "crate": "sdkwork-aiot-cloud-gateway",
            "binary": "sdkwork-aiot-cloud-gateway",
            "required": true
          },
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway-api-server",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": false
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "edge.device-ingress",
          "platform.api-gateway"
        ]
      }
    }
  },
  "scripts": {
    "devOrchestrator": "scripts/aiot-dev.mjs"
  },
  "retired": {
    "envKeys": [
      "SDKWORK_AIOT_GATEWAY_BIND",
      "SDKWORK_AIOT_APP_API_BIND",
      "SDKWORK_AIOT_ADMIN_API_BIND",
      "SDKWORK_AIOT_XIAOZHI_SIMULATOR_GATEWAY_HTTP",
      "SDKWORK_AIOT_HOSTING",
      "VITE_SDKWORK_AIOT_HOSTING"
    ],
    "notes": "Delete retired keys from active code paths; list retained here for migration audits only.",
    "vocabulary": {
      "hosting": [
        "self-hosted",
        "cloud-hosted"
      ]
    }
  },
  "packaging": {
    "cloudConfigFiles": [
      "sdkwork-api-cloud-gateway.aiot.development.toml",
      "sdkwork-api-cloud-gateway.aiot.production.toml"
    ],
    "targets": [
      {
        "id": "container-noarch-cloud-container-config-bundle-tar-gz",
        "profile": "container",
        "platform": "container",
        "architecture": "noarch",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-aiot-api-gateway-config-*.tar.gz",
        "deploymentProfile": "cloud",
        "runtimeTarget": "container",
        "variant": "config-bundle"
      }
    ]
  }
}
