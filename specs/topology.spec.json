{
  "schemaVersion": 5,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-aiot",
  "archetype": "application-rest-edge-device",
  "profileRoot": "etc/topology",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    },
    "connectivityPlane": {
      "allowed": [
        "application",
        "platform",
        "edge"
      ]
    },
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "gatewayBind": "127.0.0.1:3900",
    "desktopBuildProfileId": "standalone.production"
  },
  "profileFiles": {
    "standalone.development": "etc/topology/standalone.development.env",
    "cloud.development": "etc/topology/cloud.development.env",
    "standalone.production": "etc/topology/standalone.production.env",
    "cloud.production": "etc/topology/cloud.production.env"
  },
  "envKeys": {
    "environment": "SDKWORK_AIOT_ENVIRONMENT",
    "profileId": "SDKWORK_AIOT_PROFILE_ID",
    "apiGatewayBaseUrl": "SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL",
    "deploymentProfile": "SDKWORK_AIOT_DEPLOYMENT_PROFILE",
    "clientDeploymentProfile": "VITE_SDKWORK_AIOT_DEPLOYMENT_PROFILE"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_AIOT_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_AIOT_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_APPLICATION_PUBLIC_HTTP_URL"
    },
    "application.app-http": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_AIOT_APPLICATION_APP_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_APPLICATION_APP_HTTP_URL"
    },
    "application.admin-http": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL"
    },
    "edge.device-ingress": {
      "connectivityPlane": "edge",
      "protocols": [
        "http",
        "websocket",
        "mqtt",
        "udp"
      ],
      "bindEnv": "SDKWORK_AIOT_EDGE_DEVICE_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL",
      "websocketUrlEnv": "SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL",
      "clientWebsocketEnv": "VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL"
    }
  },
  "cloudPublicHosts": {
    "application.app-http": {
      "httpHost": "api.sdkwork.com"
    },
    "application.admin-http": {
      "httpHost": "api.sdkwork.com"
    },
    "edge.device-ingress": {
      "httpHost": "edge.aiot.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    },
    "application.public-ingress": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_AIOT",
    "devicePath": "SDKWORK_AIOT_DEVICE_DB_PATH",
    "deviceEngine": "SDKWORK_AIOT_DEVICE_DATABASE_ENGINE",
    "deviceTablePrefix": "SDKWORK_AIOT_DEVICE_DATABASE_TABLE_PREFIX",
    "deviceMode": "SDKWORK_AIOT_DEVICE_DATABASE_MODE",
    "outboxDispatcherEnabled": "SDKWORK_AIOT_OUTBOX_DISPATCHER_ENABLED",
    "outboxDispatchIntervalMs": "SDKWORK_AIOT_OUTBOX_DISPATCH_INTERVAL_MS",
    "outboxLagReadyThreshold": "SDKWORK_AIOT_OUTBOX_LAG_READY_THRESHOLD",
    "outboxWebhookUrl": "SDKWORK_AIOT_OUTBOX_WEBHOOK_URL"
  },
  "intelligence": {
    "mode": "SDKWORK_AIOT_INTELLIGENCE_MODE",
    "kernelHttpUrl": "SDKWORK_AIOT_INTELLIGENCE_KERNEL_HTTP_URL",
    "kernelAgentId": "SDKWORK_AIOT_INTELLIGENCE_KERNEL_AGENT_ID",
    "clawRouterOpenHttpUrl": "SDKWORK_CLAW_ROUTER_APPLICATION_OPEN_HTTP_URL",
    "clawRouterApiKey": "SDKWORK_CLAW_ROUTER_API_KEY",
    "asrModel": "SDKWORK_AIOT_INTELLIGENCE_ASR_MODEL",
    "ttsModel": "SDKWORK_AIOT_INTELLIGENCE_TTS_MODEL",
    "ttsVoice": "SDKWORK_AIOT_INTELLIGENCE_TTS_VOICE",
    "ttsResponseFormat": "SDKWORK_AIOT_INTELLIGENCE_TTS_RESPONSE_FORMAT",
    "ttsSampleRate": "SDKWORK_AIOT_INTELLIGENCE_TTS_SAMPLE_RATE"
  },
  "components": {
    "deviceEdgeRuntime": {
      "crate": "sdkwork-aiot-device-edge-runtime",
      "binary": "sdkwork-aiot-device-edge-runtime"
    },
    "apiAssembly": {
      "crate": "sdkwork-api-aiot-assembly"
    },
    "standaloneGateway": {
      "crate": "sdkwork-api-aiot-standalone-gateway",
      "binary": "sdkwork-api-aiot-standalone-gateway"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "script": "_sdkwork:gateway:standalone",
            "required": true,
            "role": "api-standalone-gateway"
          },
          {
            "id": "edge.device-ingress",
            "script": "_sdkwork:runtime:device-edge",
            "required": true,
            "role": "edge-runtime",
            "decisionRef": "docs/architecture/decisions/ADR-20260720-edge-split-cloud-ingress.md"
          },
          {
            "id": "aiot-pc-web",
            "script": "_sdkwork:client:browser:standalone",
            "required": true,
            "role": "client",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "pc-web"
            ]
          },
          {
            "id": "aiot-h5",
            "script": "_sdkwork:client:h5:standalone",
            "required": true,
            "role": "client",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "h5"
            ]
          },
          {
            "id": "aiot-mini-program",
            "script": "_sdkwork:client:mini-program:standalone",
            "required": true,
            "role": "client",
            "runtimeTargets": [
              "mini-program"
            ],
            "clientArchitectures": [
              "mini-program"
            ]
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "edge.device-ingress"
        ]
      },
      "cloud.development": {
        "processes": [
          {
            "id": "aiot-pc-web",
            "script": "_sdkwork:client:browser:cloud",
            "required": true,
            "role": "client",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "pc-web"
            ]
          },
          {
            "id": "aiot-h5",
            "script": "_sdkwork:client:h5:cloud",
            "required": true,
            "role": "client",
            "runtimeTargets": [
              "browser"
            ],
            "clientArchitectures": [
              "h5"
            ]
          },
          {
            "id": "aiot-mini-program",
            "script": "_sdkwork:client:mini-program:cloud",
            "required": true,
            "role": "client",
            "runtimeTargets": [
              "mini-program"
            ],
            "clientArchitectures": [
              "mini-program"
            ]
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway",
          "edge.device-ingress"
        ]
      },
      "cloud.production": {
        "processes": [],
        "healthSurfaces": []
      },
      "standalone.production": {
        "processes": [],
        "healthSurfaces": []
      }
    }
  }
}
