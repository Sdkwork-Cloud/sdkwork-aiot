{
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-aiot",
    "name": "SDKWork AIoT",
    "repository": "Sdkwork-Cloud/sdkwork-aiot",
    "sourcePath": "."
  },
  "release": {
    "artifactPrefix": "sdkwork-aiot",
    "defaultVersion": "0.1.0",
    "changelog": {
      "source": "auto",
      "maxCommitSubjects": 50
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-appbase",
      "repository": "Sdkwork-Cloud/sdkwork-appbase",
      "ref": "main",
      "refInput": "SDKWORK_APPBASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-web-framework",
      "repository": "Sdkwork-Cloud/sdkwork-web-framework",
      "ref": "main",
      "refInput": "SDKWORK_WEB_FRAMEWORK_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-database",
      "repository": "Sdkwork-Cloud/sdkwork-database",
      "ref": "main",
      "refInput": "SDKWORK_DATABASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-generator",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-generator",
      "ref": "main",
      "refInput": "SDKWORK_SDK_GENERATOR_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-app-topology",
      "repository": "Sdkwork-Cloud/sdkwork-app-topology",
      "ref": "main",
      "refInput": "SDKWORK_APP_TOPOLOGY_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-utils",
      "repository": "Sdkwork-Cloud/sdkwork-utils",
      "ref": "main",
      "refInput": "SDKWORK_UTILS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-drive",
      "repository": "Sdkwork-Cloud/sdkwork-drive",
      "ref": "main",
      "refInput": "SDKWORK_DRIVE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.33.0",
    "rust": "stable"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install workspace dependencies",
        "shell": "pwsh",
        "run": "pnpm install --no-frozen-lockfile"
      }
    ],
    "build": [
      {
        "name": "Verify workspace standards",
        "shell": "pwsh",
        "run": "pnpm check"
      },
      {
        "name": "Verify Rust workspace",
        "shell": "pwsh",
        "run": "cargo fmt -- --check; cargo clippy --workspace --tests -- -D warnings; cargo test --workspace"
      }
    ],
    "package": [
      {
        "name": "Package AIoT server binaries",
        "shell": "pwsh",
        "run": "$ErrorActionPreference = \"Stop\"\nswitch ($env:SDKWORK_PACKAGE_PROFILE) {\n  'server' {\n    cargo build --release -p sdkwork-aiot-cloud-gateway -p sdkwork-aiot-app-api -p sdkwork-aiot-admin-api\n    pnpm release:package\n  }\n  default { Write-Host \"Skipping AIoT package archive for profile $($env:SDKWORK_PACKAGE_PROFILE)\" }\n}"
      }
    ],
    "sbom": [
      {
        "name": "Write AIoT package SBOM evidence",
        "shell": "pwsh",
        "run": "pnpm sbom:generate"
      }
    ],
    "validate": [
      {
        "name": "Validate topology and OpenAPI contracts",
        "shell": "pwsh",
        "run": "pnpm test:topology-validate; pnpm test:topology-baggage; pnpm api:check; pnpm sdk:check; pnpm check:production-topology; pnpm check:deploy-manifest; pnpm check:docs-index"
      }
    ]
  },
  "targets": [
    {
      "id": "linux-x64-standalone-server-tar-gz",
      "profile": "server",
      "platform": "linux",
      "architecture": "x64",
      "formats": [
        "tar.gz"
      ],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "artifacts/release/**/*"
      ],
      "deploymentProfile": "standalone",
      "runtimeTarget": "server"
    },
    {
      "id": "windows-x64-standalone-server-zip",
      "profile": "server",
      "platform": "windows",
      "architecture": "x64",
      "formats": [
        "zip"
      ],
      "runner": "windows-latest",
      "outputGlobs": [
        "artifacts/release/**/*"
      ],
      "deploymentProfile": "standalone",
      "runtimeTarget": "server"
    }
  ],
  "security": {
    "artifactAttestations": true,
    "sbomRequired": true,
    "signingRequired": false
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": false,
    "retentionDays": 30
  }
}
