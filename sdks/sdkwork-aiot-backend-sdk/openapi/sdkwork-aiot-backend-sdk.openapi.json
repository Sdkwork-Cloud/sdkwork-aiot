{
  "openapi": "3.1.2",
  "info": {
    "title": "SDKWork AIoT Backend API",
    "version": "0.1.0",
    "description": "SDKWork AIoT backend API contract. OpenAPI is the source of truth for generated backend SDKs."
  },
  "servers": [
    {
      "url": "/backend/v3/api/iot"
    }
  ],
  "tags": [
    {
      "name": "iot",
      "description": "Operator-facing AIoT control-plane APIs."
    }
  ],
  "paths": {
    "/backend/v3/api/iot/products": {
      "parameters": [
        {
          "$ref": "#/components/parameters/SdkworkTenantId"
        },
        {
          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "get": {
        "tags": ["iot"],
        "operationId": "products.list",
        "x-sdkwork-required-permission": "iot.products.read",
        "summary": "List AIoT products",
        "security": [
          {
            "Authorization": [],
            "Access-Token": []
          }
        ],
        "responses": {
          "200": {
            "description": "Product collection.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotProductListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    },
