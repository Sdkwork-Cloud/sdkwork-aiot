          }
        }
      }
    },
    "/backend/v3/api/iot/runtime/capacity": {
      "parameters": [
        {
          "$ref": "#/components/parameters/SdkworkTenantId"
        },
        {
          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "get": {
        "tags": ["iot"],
        "operationId": "runtime.capacity.retrieve",
        "x-sdkwork-required-permission": "iot.runtime.read",
        "summary": "Retrieve AIoT runtime capacity and backpressure policy",
        "security": [
          {
            "Authorization": [],
            "Access-Token": []
          }
        ],
        "responses": {
          "200": {
            "description": "Runtime capacity policy.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotRuntimeCapacityPolicyResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Authorization": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Authorization: Bearer <auth_token>"
      },
      "Access-Token": {
        "type": "apiKey",
        "in": "header",
        "name": "Access-Token",
        "description": "SDKWork canonical access token header."
      }
    },
    "parameters": {
      "SdkworkTenantId": {
        "name": "X-Sdkwork-Tenant-Id",
        "in": "header",
        "required": true,
        "description": "Resolved tenant id provided by sdkwork-appbase IAM context.",
        "schema": {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      },
      "SdkworkOrganizationId": {
        "name": "X-Sdkwork-Organization-Id",
        "in": "header",
        "required": true,
        "description": "Resolved organization id provided by sdkwork-appbase IAM context.",
        "schema": {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      },
      "SdkworkUserId": {
        "name": "X-Sdkwork-User-Id",
        "in": "header",
        "required": false,
        "description": "Optional resolved user id provided by sdkwork-appbase IAM context.",
        "schema": {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      },
      "SdkworkDataScope": {
        "name": "X-Sdkwork-Data-Scope",
        "in": "header",
        "required": false,
        "description": "Optional resolved SDKWork data-scope integer.",
        "schema": {
          "type": "string",
          "pattern": "^-?[0-9]+$"
        }
      },
      "SdkworkPermissionScope": {
        "name": "X-Sdkwork-Permission-Scope",
        "in": "header",
        "required": true,
        "description": "Comma-separated permissions resolved by sdkwork-appbase IAM context.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      },
      "DeviceId": {
        "name": "deviceId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": false,
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "responses": {
      "Problem": {
        "description": "Problem details.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      }
    },
    "schemas": {
      "AiotProductListResponse": {
        "$ref": "#/components/schemas/StandardCollectionResponse"
      },
      "AiotHardwareProfileListResponse": {
        "$ref": "#/components/schemas/StandardCollectionResponse"
      },
      "AiotProtocolProfileListResponse": {
        "$ref": "#/components/schemas/StandardCollectionResponse"
      },
      "AiotCapabilityModelResponse": {
        "$ref": "#/components/schemas/StandardResourceResponse"
      },
      "AiotDeviceListResponse": {
        "$ref": "#/components/schemas/StandardCollectionResponse"
      },
      "AiotCredentialCreateRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["credentialType"],
        "properties": {
          "credentialType": {
            "type": "string",
            "enum": ["bearer_token", "hmac", "mtls_x509", "hardware_attestation"]
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AiotCredentialResponse": {
        "$ref": "#/components/schemas/StandardResourceResponse"
      },
      "AiotFirmwareArtifactCreateRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactKey", "version", "fileName", "storageUri", "sha256"],
        "properties": {
          "artifactKey": {
            "type": "string",
            "maxLength": 128
          },
          "version": {
            "type": "string",
            "maxLength": 128
          },
          "fileName": {
            "type": "string",
            "maxLength": 256
          },
          "storageUri": {
            "type": "string",
            "maxLength": 512
          },
          "sha256": {
            "type": "string",
            "minLength": 64,
            "maxLength": 128
          },
          "signature": {
            "type": "string"
          }
        }
      },
      "AiotFirmwareArtifactResponse": {
        "$ref": "#/components/schemas/StandardResourceResponse"
      },
      "AiotFirmwareRolloutCreateRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactId", "targetPolicy"],
        "properties": {
          "artifactId": {
            "type": "string"
          },
          "targetPolicy": {
            "$ref": "#/components/schemas/JsonValue"
          }
        }
      },
      "AiotFirmwareRolloutResponse": {
        "$ref": "#/components/schemas/StandardResourceResponse"
      },
      "AiotProtocolAdapterListResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AiotProtocolAdapter"
            }
          }
        }
      },
      "AiotProtocolAdapter": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "protocolId",
          "pluginId",
          "scope",
          "transport",
          "transports",
          "codecs",
          "sessionPolicies",
          "securityModes",
          "hardwareFamilies",
          "runtimeProfiles",
          "firmwareProfiles",
          "kind"
        ],
        "properties": {
          "path": {
            "type": "string",
            "maxLength": 256
          },
          "protocolId": {
            "type": "string",
            "maxLength": 128,
            "examples": ["xiaozhi.websocket", "mqtt.v5", "coap.lwm2m", "modbus.bridge"]
          },
          "pluginId": {
            "type": "string",
            "maxLength": 128
          },
          "scope": {
            "type": "string",
            "enum": ["StandardAdapter", "CompatibilityPlugin", "BridgeAdapter"]
          },
          "transport": {
            "$ref": "#/components/schemas/AiotTransportBinding"
          },
          "transports": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AiotTransportBinding"
            }
          },
          "codecs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AiotCodecKind"
            }
          },
          "sessionPolicies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AiotSessionPolicy"
            }
          },
          "securityModes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AiotDeviceAuthMode"
            }
          },
          "hardwareFamilies": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 128
            }
          },
          "runtimeProfiles": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 128
            }
          },
          "firmwareProfiles": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 128
            }
          },
          "kind": {
            "type": "string",
            "enum": ["deviceSession", "otaMetadata", "provisioning", "bridgeIngress", "callback"]
          }
        }
      },
      "AiotTransportBinding": {
        "type": "string",
        "enum": ["Tcp", "Udp", "WebSocket", "Http", "Mqtt", "Coap", "Serial", "Ble"]
      },
      "AiotCodecKind": {
        "type": "string",
        "enum": [
          "JsonText",
          "BinaryMedia",
          "BinaryPayload",
          "JsonRpc",
          "Protobuf",
          "Cbor",
          "TopicPayload",
          "RegisterMap"
        ]
      },
      "AiotSessionPolicy": {
        "type": "string",
        "enum": [
          "StatefulDeviceSession",
          "StatelessUplink",
          "BrokerSession",
          "BridgeSession",
          "GatewayMultiplexedSession"
        ]
      },
      "AiotDeviceAuthMode": {
        "type": "string",
        "enum": [
          "bearer_token",
          "hmac",
          "mtls_x509",
          "hardware_attestation",
          "broker_credential",
          "bridge_trust"
        ]
      },
      "AiotRuntimeCapacityPolicyResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/AiotRuntimeCapacityPolicy"
          }
        }
      },
      "AiotRuntimeCapacityPolicy": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "nodeId",
          "maxConnectionsPerNode",
          "maxSessionsPerTenant",
          "maxInflightPerDevice",
          "sessionLeaseTtlSeconds",
          "sessionLeaseRenewSeconds",
          "outboxMaxAttempts",
          "deadLetterAfterAttempts",
          "backpressure"
        ],
        "properties": {
          "nodeId": {
            "type": "string"
          },
          "maxConnectionsPerNode": {
            "type": "string",
            "description": "int64 serialized as string."
          },
          "maxSessionsPerTenant": {
            "type": "string",
            "description": "int64 serialized as string."
          },
          "maxInflightPerDevice": {
            "type": "integer",
            "minimum": 1
          },
          "sessionLeaseTtlSeconds": {
            "type": "integer",
            "minimum": 1
          },
          "sessionLeaseRenewSeconds": {
            "type": "integer",
            "minimum": 1
          },
          "outboxMaxAttempts": {
            "type": "integer",
            "minimum": 1
          },
          "deadLetterAfterAttempts": {
            "type": "integer",
            "minimum": 1
          },
          "backpressure": {
            "type": "object",
            "additionalProperties": false,
            "required": ["warnLag", "rejectLag", "deadLetterLag"],
            "properties": {
              "warnLag": {
                "type": "string",
                "description": "int64 serialized as string."
              },
              "rejectLag": {
                "type": "string",
                "description": "int64 serialized as string."
              },
              "deadLetterLag": {
                "type": "string",
                "description": "int64 serialized as string."
              }
            }
          },
          "orderedDeviceCommands": {
            "type": "boolean"
          },
          "idempotentIngest": {
            "type": "boolean"
          }
        }
      },
      "StandardCollectionResponse": {
