            }
          }
        ],
        "responses": {
          "200": {
            "description": "Capability model.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotCapabilityModelResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    },
    "/backend/v3/api/iot/devices": {
