          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "post": {
        "tags": ["iot"],
        "operationId": "devices.credentials.create",
        "x-sdkwork-required-permission": "iot.devices.write",
        "summary": "Create device credential",
        "security": [
          {
            "Authorization": [],
            "Access-Token": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DeviceId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiotCredentialCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Credential metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotCredentialResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    },
    "/backend/v3/api/iot/firmware_artifacts": {
      "parameters": [
        {
