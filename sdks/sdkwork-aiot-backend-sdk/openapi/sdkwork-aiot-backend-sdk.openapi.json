        }
      ],
      "post": {
        "tags": ["iot"],
        "operationId": "firmwareArtifacts.create",
        "x-sdkwork-required-permission": "iot.firmware.write",
        "summary": "Create firmware artifact metadata",
        "security": [
          {
            "Authorization": [],
            "Access-Token": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiotFirmwareArtifactCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Firmware artifact.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotFirmwareArtifactResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    },
    "/backend/v3/api/iot/firmware_rollouts": {
      "parameters": [
        {
          "$ref": "#/components/parameters/SdkworkTenantId"
        },
        {
          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "post": {
        "tags": ["iot"],
        "operationId": "firmwareRollouts.create",
        "x-sdkwork-required-permission": "iot.firmware.rollout",
        "summary": "Create firmware rollout",
        "security": [
          {
            "Authorization": [],
            "Access-Token": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiotFirmwareRolloutCreateRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Firmware rollout accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotFirmwareRolloutResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    },
    "/backend/v3/api/iot/protocol_adapters": {
      "parameters": [
        {
          "$ref": "#/components/parameters/SdkworkTenantId"
        },
        {
          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "get": {
        "tags": ["iot"],
        "operationId": "protocolAdapters.list",
        "x-sdkwork-required-permission": "iot.protocolAdapters.read",
        "summary": "List protocol adapters",
        "security": [
          {
            "Authorization": [],
            "Access-Token": []
          }
        ],
        "responses": {
          "200": {
            "description": "Protocol adapters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotProtocolAdapterListResponse"
                }
              }
            }
          },
          "default": {
