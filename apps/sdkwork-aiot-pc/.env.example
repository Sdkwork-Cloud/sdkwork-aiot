# SDKWork AIoT PC — optional local overrides.
# Full stack development uses repository-root topology profiles:
#   pnpm dev
#   pnpm dev:server:sqlite:split-services:cloud

# Application surfaces (default from configs/topology/self-hosted.split-services.development.env)
VITE_SDKWORK_AIOT_APPLICATION_APP_HTTP_URL=http://127.0.0.1:18082
VITE_SDKWORK_AIOT_APPLICATION_ADMIN_HTTP_URL=http://127.0.0.1:18081
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_HTTP_URL=http://127.0.0.1:18080
VITE_SDKWORK_AIOT_EDGE_DEVICE_INGRESS_WEBSOCKET_URL=ws://127.0.0.1:18080

# Platform API gateway (IAM, Drive, Agents, Voice)
VITE_SDKWORK_AIOT_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_DRIVE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_SDKWORK_AGENTS_APP_API_BASE_URL=http://127.0.0.1:8095
VITE_SDKWORK_VOICE_APP_API_BASE_URL=http://127.0.0.1:18096
VITE_SDKWORK_AIOT_AGENTS_DEFAULT_AGENT_ID=agent.aiot.assistant
VITE_SDKWORK_AIOT_VOICE_DEFAULT_MODEL=tts-1
VITE_SDKWORK_AIOT_VOICE_DEFAULT_VOICE=alloy
VITE_SDKWORK_AIOT_VOICE_TRANSCRIPTION_MODEL=whisper-1

# SDKWork private bootstrap credential (blank in tracked files).
SDKWORK_ACCESS_TOKEN=
